package search;
import java.util.Scanner;
public class StringSearch {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        System.out.println("Enter the main string (can include spaces):");
        String text = scanner.nextLine();
        System.out.println("Enter the pattern string (can include spaces):");
        String pattern = scanner.nextLine();
        int comparisons = 0;
        int alignments = 0;
        int n = text.length();
        int m = pattern.length();
        boolean found = false;
        System.out.println();
        for (int i = 0; i <= n - m; i++) {
            alignments++;
            System.out.println("Alignment " + alignments + " (text index " + i + "):");
            System.out.println(text);
            for (int k = 0; k < i; k++) {
                System.out.print(" ");
            }
            System.out.println(pattern);
            comparisons++;
            if (text.charAt(i) != pattern.charAt(0)) {
                for (int j = 0; j < i; j++) {
                    System.out.print(" ");
                }
                System.out.println("X" + " ".repeat(m - 1));
                System.out.println();
                continue;
            }
            for (int j = 0; j < i; j++) {
                System.out.print(" ");
            }
            boolean matched = true;
            System.out.print("|");
            for (int j = 1; j < m; j++) {
                comparisons++;
                if (text.charAt(i + j) == pattern.charAt(j)) {
                    System.out.print("|");
                } else {
                    System.out.print("X");
                    matched = false;
                }
            }
            System.out.println();
            if (matched) {
                System.out.println("Pattern found at index " + i + "\n");
                found = true;
                break;
            } else {
                System.out.println();
            }
        }
        if (!found) {
            System.out.println("Pattern not found in the text.");
        }
        System.out.println("Total alignments tried: " + alignments);
        System.out.println("Total character comparisons: " + comparisons);
        scanner.close();
    }
}

