import java.util.*;

class BubbleSort {
   public void sortedArray(int[] a,int n){
      for(int i=0;i<=n-2;i++){
         System.out.println("\nPass "+(i+1)+": ");
         for(int j=0;j<=n-2-i;j++){
            if(a[j]>a[j+1]){
               int temp=a[j];
               a[j]=a[j+1];
               a[j+1]=temp;
            }
         }
         for(int elt:a){
            System.out.print(elt+"\t");
         }
      }
   }
}

