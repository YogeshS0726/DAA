import java.util.*;

class SelectionSort {
        public void sortedArray(int[] a,int n){
                int min;
                for(int i=0;i<=n-2;i++){
                        min=i;
                        for(int j=i+1;j<=n-1;j++){
                                if(a[min]>a[j]){
                                        min=j;
                                }
                        }
                        int temp=a[min];
                        a[min]=a[i];
                        a[i]=temp;
                        System.out.print("\nPass " + (i+1) +": ");
                        for(int elt:a){
                                System.out.print(elt+"\t");
                        }
                }
        }
}

