HorsPool's Algorithm

package myjava;
import java.util.Scanner;
public class HorsPool {
    private static int[] buildShiftTable(String pattern) {
        int m = pattern.length();
        int[] shiftTable = new int[26];
        for (int i = 0; i < 26; i++) {
            shiftTable[i] = m;
        }
        for (int i = 0; i < m - 1; i++) {
            char c = Character.toUpperCase(pattern.charAt(i));
            if (c >= 'A' && c <= 'Z') {
                shiftTable[c - 'A'] = m - 1 - i;
            }
        }
        return shiftTable;
    }
    private static void displayAlignment(String text, String pattern, int startIndex, int matchedCount) {
        System.out.println("\nText:    " + text);
        for (int i = 0; i < startIndex; i++) {
            System.out.print(" ");
        }
        System.out.println("\nPattern: " + pattern);
        for (int i = 0; i < startIndex; i++) {
            System.out.print(" ");
        }
        for (int i = 0; i < pattern.length(); i++) {
            if (i < matchedCount) {
                System.out.print("|");
            } else if (i == matchedCount) {
                System.out.print("^");
            } else {
                System.out.print(" ");
            }
        }
        System.out.println();
    }
    public static void horspoolSearch(String text, String pattern) {
        int n = text.length();
        int m = pattern.length();

        if (m > n) {
            System.out.println("Pattern length is greater than text length. No match possible.");
            return;
        }
        int[] shiftTable = buildShiftTable(pattern);
        System.out.println("\nShift Table for A-Z:");
        for (char c = 'A'; c <= 'Z'; c++) {
            System.out.println("'" + c + "' = " + shiftTable[c - 'A']);
        }
        int i = m - 1;
        while (i < n) {
            int k = 0;
            int startIndex = i - m + 1;
            System.out.println("\nAlign pattern at text index: " + startIndex);
            displayAlignment(text, pattern, startIndex, k);
            while (k < m &&
                   Character.toUpperCase(pattern.charAt(m - 1 - k)) == Character.toUpperCase(text.charAt(i - k))) {
                k++;
                displayAlignment(text, pattern, startIndex, k);
            }
            if (k == m) {
                System.out.println("Pattern found at index " + startIndex);
                return;
            } else {
                char mismatchChar = Character.toUpperCase(text.charAt(i));
                int shift;
                if (mismatchChar >= 'A' && mismatchChar <= 'Z') {
                    shift = shiftTable[mismatchChar - 'A'];
                } else {
                    shift = m; // Default shift if out of range
                }
                System.out.println("Mismatch at text index " + (i - k) + " (text char '" + text.charAt(i - k) + "'), pattern index " + (m - 1 - k));
                System.out.println("Character causing mismatch: '" + mismatchChar + "'");
                System.out.println("Shifting pattern by " + shift + " position(s)");
                i += shift;
            }
        }
        System.out.println("Pattern not found in the text.");
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter the text: ");
        String text = sc.nextLine();
        System.out.print("Enter the pattern to search: ");
        String pattern = sc.nextLine();
        horspoolSearch(text, pattern);
        sc.close();
    }
}

